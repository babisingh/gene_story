# Gene Story — Environment Configuration Template
# Copy this file to .env and fill in your values:
#   cp .env.example .env

# ── Anthropic API Key ──────────────────────────────────────────────────────────
# Get your key from: https://console.anthropic.com
# This key is used to generate gene stories via the Claude API.
ANTHROPIC_API_KEY=sk-ant-your-key-here

# ── PostgreSQL Database ────────────────────────────────────────────────────────
# These values are used by both the database container and the API server.
# Change POSTGRES_PASSWORD to something secure before deploying.
POSTGRES_USER=genestory
POSTGRES_PASSWORD=changeme
POSTGRES_DB=genestory

# This URL is assembled from the values above.
# "postgres" is the Docker service name — it works inside Docker Compose.
# When running outside Docker, change "postgres" to "localhost".
DATABASE_URL=postgresql://genestory:changeme@postgres:5432/genestory

# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
